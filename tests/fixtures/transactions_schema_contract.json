{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Transaction",
  "type": "object",
  "required": [
    "transaction_id",
    "account_id",
    "transaction_date",
    "amount",
    "currency",
    "transaction_type",
    "merchant_name",
    "merchant_category",
    "status",
    "country_code"
  ],
  "additionalProperties": false,
  "properties": {
    "transaction_id": {
      "type": "string",
      "pattern": "^TXN-[A-Z0-9]+$"
    },
    "account_id": {
      "type": "string",
      "pattern": "^ACC-\\d{4}$"
    },
    "transaction_date": {
      "type": "string",
      "format": "date-time",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])T([01]\\d|2[0-3]):[0-5]\\d:[0-5]\\dZ$"
    },
    "amount": {
      "type": "number",
      "exclusiveMinimum": 0,
      "multipleOf": 0.01
    },
    "currency": {
      "type": "string",
      "enum": ["USD", "EUR", "GBP", "CHF", "JPY", "AUD", "CAD"]
    },
    "transaction_type": {
      "type": "string",
      "enum": ["debit", "credit"]
    },
    "merchant_name": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "merchant_category": {
      "type": "string",
      "enum": [
        "e-commerce",
        "travel",
        "food_and_beverage",
        "groceries",
        "electronics",
        "retail",
        "entertainment",
        "health",
        "transportation",
        "home_and_garden",
        "payroll",
        "transfer"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["completed", "pending", "failed", "reversed"]
    },
    "country_code": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "minLength": 2,
      "maxLength": 2
    }
  }
}
